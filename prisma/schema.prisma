generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("funcionario") // admin ou funcionario
  active    Boolean  @default(true)
  avatar    String?  // Base64 da foto de perfil
  telefone  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordensServico OrdemServico[]
}

model Configuracao {
  id              String   @id @default(cuid())
  logoEmpresa     String?  // Base64 do logo
  nomeEmpresa     String   @default("Supreme Detalhamento")
  cnpjEmpresa     String?
  telefoneEmpresa String?
  emailEmpresa    String?
  enderecoEmpresa String?
  instagramEmpresa String?
  facebookEmpresa  String?
  whatsappEmpresa  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Cliente {
  id          String   @id @default(cuid())
  nome        String
  cpfCnpj     String?
  telefone    String?
  whatsapp    String?
  email       String?
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  veiculos       Veiculo[]
  ordensServico  OrdemServico[]
  contasReceber  ContaReceber[]
}

model Veiculo {
  id          String   @id @default(cuid())
  clienteId   String
  tipo        String   // carro ou moto
  marca       String
  modelo      String
  ano         String?
  placa       String?
  cor         String?
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente       Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  ordensServico OrdemServico[]
}

model Produto {
  id            String   @id @default(cuid())
  nome          String
  categoria     String?
  marca         String?
  quantidade    Int      @default(0)
  valorUnitario Float    @default(0)
  estoqueMinimo Int      @default(5)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  itensOrdem ItemOrdem[]
}

model Servico {
  id        String   @id @default(cuid())
  nome      String
  descricao String?
  valor     Float    @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itensOrdem   ItemOrdem[]
  agendamentos Agendamento[]
}

model OrdemServico {
  id              String   @id @default(cuid())
  numero          Int      @unique @default(autoincrement())
  clienteId       String
  veiculoId       String
  funcionarioId   String
  status          String   @default("aberta") // aberta, em_andamento, finalizada, entregue
  valorTotal      Float    @default(0)
  dataEntrada     DateTime @default(now())
  dataSaida       DateTime?
  observacoes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cliente       Cliente       @relation(fields: [clienteId], references: [id])
  veiculo       Veiculo       @relation(fields: [veiculoId], references: [id])
  funcionario   User          @relation(fields: [funcionarioId], references: [id])
  itens         ItemOrdem[]
  contasReceber ContaReceber[]
}

model ItemOrdem {
  id             String   @id @default(cuid())
  ordemServicoId String
  produtoId      String?
  servicoId      String?
  tipo           String   // produto ou servico
  descricao      String
  quantidade     Int      @default(1)
  valorUnitario  Float
  valorTotal     Float
  createdAt      DateTime @default(now())

  ordemServico OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  produto      Produto?     @relation(fields: [produtoId], references: [id])
  servico      Servico?     @relation(fields: [servicoId], references: [id])
}

model ContaPagar {
  id          String   @id @default(cuid())
  descricao   String
  categoria   String?
  valor       Float
  vencimento  DateTime
  status      String   @default("pendente") // pago ou pendente
  dataPago    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContaReceber {
  id              String   @id @default(cuid())
  clienteId       String
  ordemServicoId  String?
  descricao       String?
  valor           Float
  formaPagamento  String?
  status          String   @default("pendente") // recebido ou pendente
  dataRecebido    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cliente      Cliente       @relation(fields: [clienteId], references: [id])
  ordemServico OrdemServico? @relation(fields: [ordemServicoId], references: [id])
}

// ================================
// SISTEMA DE AGENDAMENTO ONLINE
// ================================

model Agendamento {
  id              String   @id @default(cuid())
  nomeCliente     String
  telefone        String
  email           String?
  tipoVeiculo     String   // carro ou moto
  marcaVeiculo    String
  modeloVeiculo   String
  placaVeiculo    String?
  corVeiculo      String?
  servicoId       String?
  servicoNome     String   // Nome do serviço solicitado
  dataAgendamento DateTime
  horario         String   // Ex: "09:00", "10:00"
  observacoes     String?
  status          String   @default("pendente") // pendente, confirmado, cancelado, concluido
  token           String   @unique @default(cuid()) // Token único para o cliente acessar/cancelar
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  servico Servico? @relation(fields: [servicoId], references: [id])
}

model HorarioDisponivel {
  id        String   @id @default(cuid())
  diaSemana Int      // 0=Domingo, 1=Segunda, ..., 6=Sábado
  horario   String   // Ex: "09:00"
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BloqueioAgenda {
  id         String   @id @default(cuid())
  data       DateTime
  motivo     String?
  diaInteiro Boolean  @default(true)
  horarios   String?  // JSON com horários bloqueados se não for dia inteiro
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ConfiguracaoAgendamento {
  id                        String   @id @default(cuid())
  servicosDisponiveis       String   // JSON com IDs dos serviços disponíveis para agendamento
  horariosDisponiveis       String   // JSON com horários disponíveis ex: ["08:00", "09:00", "10:00"]
  maxVagasPorHorario        Int      @default(2)
  regrasPorServico          String?  // JSON com regras por serviço: [{servicoId, maxVagas, horarios}]
  diasSemanaAtivos          String   @default("[1,2,3,4,5,6]") // JSON com dias da semana ativos (0=Dom, 6=Sab)
  mensagemConfirmacao       String?  // Mensagem personalizada após agendamento
  // Configuração específica para Lavagem Técnica
  servicoLavagemTecnicaId   String?  // ID do serviço de lavagem técnica
  horariosLavagemTecnica    String?  // JSON com horários específicos para lavagem técnica
  maxVagasLavagemTecnica    Int      @default(1) // Máximo de vagas por horário para lavagem técnica
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model Orcamento {
  id              String   @id @default(cuid())
  numero          Int      @default(autoincrement()) // Número sequencial do orçamento
  // Dados do cliente
  nomeCliente     String
  telefoneCliente String?
  emailCliente    String?
  // Dados do veículo
  veiculoMarca    String?
  veiculoModelo   String?
  veiculoPlaca    String?
  veiculoCor      String?
  veiculoAno      String?
  // Valores
  valorTotal      Float    @default(0)
  desconto        Float    @default(0)
  valorFinal      Float    @default(0)
  // Observações e validade
  observacoes     String?
  validade        DateTime? // Data de validade do orçamento
  status          String   @default("pendente") // pendente, aprovado, recusado, expirado
  // Itens do orçamento (JSON com array de itens)
  itens           String   @default("[]") // JSON: [{descricao, quantidade, valorUnitario, valorTotal}]
  responsavel     String?  // Nome do responsável que fez o orçamento
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
